<div class="tab faction-status-tab" data-group="{{tabGroup}}" data-tab="faction-status">
  <section class="faction-status-header">
    <h3>{{labels.header}}</h3>
    <button type="button" class="faction-group-add-global" {{#unless permissions.canManageStructure}}disabled{{/unless}}>{{labels.addGroup}}</button>
  </section>

  <section class="faction-status-list">
    {{#if groups.length}}
      {{#each groups as |group groupIndex|}}
        <section class="faction-group-card{{#if group.collapsed}} is-collapsed{{/if}}" data-group-id="{{group.id}}" data-group-index="{{groupIndex}}">
          <div class="faction-group-header">
            <div class="faction-group-main">
              <button
                type="button"
                class="faction-group-toggle"
                data-group-id="{{group.id}}"
                data-group-index="{{groupIndex}}"
                aria-label="{{../labels.toggleGroupAria}}"
                title="{{../labels.toggleGroupAria}}"
                aria-expanded="{{#if group.collapsed}}false{{else}}true{{/if}}"
              >
                <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
              </button>
              <input
                type="text"
                class="faction-group-name"
                data-group-index="{{groupIndex}}"
                value="{{group.name}}"
                aria-label="{{../labels.groupName}}"
                {{#unless ../permissions.canManageStructure}}disabled{{/unless}}
              />
            </div>

            <div class="faction-group-actions">
              <span class="faction-count-badge" title="{{../labels.factionCountLabel}}">{{group.factions.length}}</span>
              <button
                type="button"
                class="faction-group-move icon-button"
                data-group-index="{{groupIndex}}"
                data-direction="up"
                aria-label="{{../labels.moveGroupUpAria}}"
                title="{{../labels.moveGroupUpAria}}"
                {{#unless ../permissions.canManageStructure}}disabled{{/unless}}
              >
                <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
              </button>
              <button
                type="button"
                class="faction-group-move icon-button"
                data-group-index="{{groupIndex}}"
                data-direction="down"
                aria-label="{{../labels.moveGroupDownAria}}"
                title="{{../labels.moveGroupDownAria}}"
                {{#unless ../permissions.canManageStructure}}disabled{{/unless}}
              >
                <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
              </button>
              <button
                type="button"
                class="faction-status-add icon-button"
                data-group-index="{{groupIndex}}"
                aria-label="{{../labels.addFactionAria}}"
                title="{{../labels.addFactionAria}}"
                {{#unless ../permissions.canManageStructure}}disabled{{/unless}}
              >
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
              </button>
              <button
                type="button"
                class="faction-group-delete icon-button"
                data-group-index="{{groupIndex}}"
                aria-label="{{../labels.deleteGroupAria}}"
                title="{{../labels.deleteGroupAria}}"
                {{#unless ../permissions.canManageStructure}}disabled{{/unless}}
              >
                <i class="fa-solid fa-trash" aria-hidden="true"></i>
              </button>
            </div>
          </div>

          <div class="faction-group-body">
            <div class="faction-group-columns" aria-hidden="true">
              <span>{{../labels.name}}</span>
              <span>{{../labels.status}}</span>
              <span>{{../labels.actions}}</span>
            </div>

            {{#if group.factions.length}}
              <div class="faction-group-factions">
              {{#each group.factions as |faction factionIndex|}}
                <div class="faction-status-row" data-group-index="{{groupIndex}}" data-faction-index="{{factionIndex}}">
                  <input
                    type="text"
                    class="faction-status-name"
                    data-group-index="{{groupIndex}}"
                    data-faction-index="{{factionIndex}}"
                    value="{{faction.name}}"
                    aria-label="{{../../labels.name}}"
                    {{#unless ../../permissions.canManageStructure}}disabled{{/unless}}
                  />

                  <div class="faction-status-stepper">
                    <button
                      type="button"
                      class="faction-status-step icon-button"
                      data-group-index="{{groupIndex}}"
                      data-faction-index="{{factionIndex}}"
                      data-delta="-1"
                      aria-label="{{../../labels.decreaseStatusAria}}"
                      title="{{../../labels.decreaseStatusAria}}"
                      {{#unless ../../permissions.canEditValues}}disabled{{/unless}}
                    >
                      <i class="fa-solid fa-minus" aria-hidden="true"></i>
                    </button>
                    <input
                      type="number"
                      class="faction-status-value"
                      data-group-index="{{groupIndex}}"
                      data-faction-index="{{factionIndex}}"
                      value="{{faction.value}}"
                      step="1"
                      aria-label="{{../../labels.status}}"
                      {{#unless ../../permissions.canEditValues}}disabled{{/unless}}
                    />
                    <button
                      type="button"
                      class="faction-status-step icon-button"
                      data-group-index="{{groupIndex}}"
                      data-faction-index="{{factionIndex}}"
                      data-delta="1"
                      aria-label="{{../../labels.increaseStatusAria}}"
                      title="{{../../labels.increaseStatusAria}}"
                      {{#unless ../../permissions.canEditValues}}disabled{{/unless}}
                    >
                      <i class="fa-solid fa-plus" aria-hidden="true"></i>
                    </button>
                  </div>

                  <div class="faction-status-actions">
                    <button
                      type="button"
                      class="faction-status-move icon-button"
                      data-group-index="{{groupIndex}}"
                      data-faction-index="{{factionIndex}}"
                      data-direction="up"
                      aria-label="{{../../labels.moveFactionUpAria}}"
                      title="{{../../labels.moveFactionUpAria}}"
                      {{#unless ../../permissions.canManageStructure}}disabled{{/unless}}
                    >
                      <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
                    </button>
                    <button
                      type="button"
                      class="faction-status-move icon-button"
                      data-group-index="{{groupIndex}}"
                      data-faction-index="{{factionIndex}}"
                      data-direction="down"
                      aria-label="{{../../labels.moveFactionDownAria}}"
                      title="{{../../labels.moveFactionDownAria}}"
                      {{#unless ../../permissions.canManageStructure}}disabled{{/unless}}
                    >
                      <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
                    </button>
                    <button
                      type="button"
                      class="faction-status-delete icon-button"
                      data-group-index="{{groupIndex}}"
                      data-faction-index="{{factionIndex}}"
                      aria-label="{{../../labels.deleteFactionAria}}"
                      title="{{../../labels.deleteFactionAria}}"
                      {{#unless ../../permissions.canManageStructure}}disabled{{/unless}}
                    >
                      <i class="fa-solid fa-trash" aria-hidden="true"></i>
                    </button>
                  </div>
                </div>
              {{/each}}
              </div>
            {{else}}
              <p class="faction-status-empty">{{../labels.empty}}</p>
            {{/if}}
          </div>
        </section>
      {{/each}}
    {{else}}
      <p class="faction-status-empty">{{labels.emptyGroups}}</p>
    {{/if}}
  </section>
</div>
